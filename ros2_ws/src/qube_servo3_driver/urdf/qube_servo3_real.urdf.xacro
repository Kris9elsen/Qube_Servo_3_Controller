<?xml version="1.0"?>
<robot name="qube_servo_3_real" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- arguments that can be passed from launch file -->
  <xacro:arg name="board_type" default="q8_usb"/>
  <xacro:arg name="board_identifier" default="0"/>

  <!-- world link -->
  <link name="world"/>

  <!-- base link -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.1 0.1 0.05"/>
      </geometry>
      <material name="red">
        <color rgba="1 0 0 1"/>
      </material>
    </visual>
  </link>

  <!-- rotor link -->
  <link name="rotor_link">
    <visual>
      <geometry>
        <cylinder radius="0.02" length="0.05"/>
      </geometry>
      <material name="green">
        <color rgba="0 1 0 1"/>
      </material>
    </visual>
  </link>

  <!-- pendulum link -->
  <link name="pendulum_link">
    <visual>
      <geometry>
        <cylinder radius="0.005" length="0.2"/>
      </geometry>
      <material name="orange">
        <color rgba="1 0.5 0 1"/>
      </material>
    </visual>
  </link>

  <!-- base to world joint -->
  <joint name="base_joint" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- rotor joint (motor) -->
  <joint name="rotor_joint" type="revolute">
    <parent link="base_link"/>
    <child link="rotor_link"/>
    <origin xyz="0 0 0.025" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="1.5" velocity="100" lower="-3.14159" upper="3.14159"/>
  </joint>

  <!-- pendulum joint -->
  <joint name="pendulum_joint" type="revolute">
    <parent link="rotor_link"/>
    <child link="pendulum_link"/>
    <origin xyz="0.025 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="0.1" velocity="100" lower="-3.14159" upper="3.14159"/>
  </joint>

</robot>