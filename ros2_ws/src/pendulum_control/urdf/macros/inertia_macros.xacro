<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

<xacro:macro name="simple_inertia" params="mass">

<inertial>
  <mass value="${mass}"/>
  <origin xyz="0 0 0"/>

  <inertia
    ixx="0.001"
    iyy="0.001"
    izz="0.001"
    ixy="0"
    ixz="0"
    iyz="0"/>

</inertial>

</xacro:macro>

</robot>
