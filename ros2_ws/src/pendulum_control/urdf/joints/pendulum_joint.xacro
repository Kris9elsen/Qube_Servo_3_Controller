<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="joint_macros">

  <xacro:macro name="pendulum_joint" params="">
    <joint name="pendulum_joint" type="revolute">

      <parent link="rotor_link"/>
      <child link="pendulum_link"/>

      <origin xyz="0 0 ${rotor_radius}" rpy="0 1.5708 0"/>

      <axis xyz="0 1 0"/>

      <limit effort="2" velocity="20" lower="-3.14" upper="3.14"/>

    </joint>
  </xacro:macro>

</robot>
