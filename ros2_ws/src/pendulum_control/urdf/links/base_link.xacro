<?xml version="1.0"?>
<robot xmlns:xacro="htpp://www.ros.org/wiki/xacro">

<link name="base_link">

  <visual>
    <geometry>
      <box size="${base_size} ${base_size} ${base_height}"/>
    </geometry>
  </visual>

  <collision>
    <geometry>
      <box size="${base_size} ${base_size} ${base_height}"/>
    </geometry>
  </collision>

  <xacro:simple_inertia mass="${base_mass}"/>

</link>

</robot>
