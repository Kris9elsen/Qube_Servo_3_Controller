<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="link_macros">

  <xacro:macro name="rotor_link" params="rotor_radius rotor_length rotor_mass">
    <link name="rotor_link">

      <!-- Inertia -->
      <xacro:cyl_inertia mass="${rotor_mass}" radius="${rotor_radius}" length="${rotor_length}"/>

    </link>
  </xacro:macro>

</robot>
